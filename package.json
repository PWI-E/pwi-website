{
  "name": "pwi-website",
  "version": "1.0.0",
  "description": "PWI Electronics website",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./tailwind_theme/src.css -o ./tailwind_theme/tailwind.css",
    "watch:css": "tailwindcss -i ./tailwind_theme/src.css -o ./tailwind_theme/tailwind.css --watch",
    "build:css:min": "tailwindcss -i ./tailwind_theme/src.css -o ./tailwind_theme/tailwind.min.css --minify",
    "build:search": "node _build/build-search-index.mjs",
    "build:deploy": "bash _build/build-deploy.sh",
    "build:sitemap": "node _build/update-sitemap-lastmod.mjs",
    "export:cookies-privacy-pdf": "node _build/export-cookies-privacy-pdf.mjs",
    "qa:lighthouse": "node _build/qa-lighthouse.mjs",
    "qa:lighthouse:full": "node _build/qa-lighthouse.mjs --full",
    "qa:seo": "node _build/qa-seo-audit.mjs",
    "qa:mobile-text": "node _build/qa-mobile-text.mjs"
  },
  "devDependencies": {
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^13.4.0",
    "playwright": "^1.61.1",
    "tailwindcss": "3.4.3"
  },
  "dependencies": {
    "docx": "^9.7.1"
  }
}
