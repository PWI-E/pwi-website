ErrorDocument 404 /404.html

# Canonical host: https://pwi-e.com (matches link rel="canonical" across the site)
RewriteEngine On
RewriteCond %{HTTP_HOST} ^www\.pwi-e\.com [NC]
RewriteRule ^ https://pwi-e.com%{REQUEST_URI} [L,R=301]
RewriteCond %{HTTPS} off
RewriteRule ^ https://pwi-e.com%{REQUEST_URI} [L,R=301]

Header set Cache-Control "no-cache, must-revalidate" "expr=%{CONTENT_TYPE} == 'application/pdf'"
Header always set X-Frame-Options "SAMEORIGIN"
